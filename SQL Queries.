CREATION OF THE CLEANED TABLE.......
SELECT *
INTO clean_sales
FROM samsung_global_sales_dataset
WHERE revenue_usd > 0
AND customer_rating BETWEEN 1 AND 5;---------------------------------creates a new table called clean_sales with records that have positive revenue and customer ratings between 1 and 5.

select * from clean_sales;----------------------------------------------selects all records from the clean_sales table.

WITH cohort AS (
    SELECT 
        sale_id,
        MIN(sale_date) AS cohort_date
    FROM clean_sales
    GROUP BY sale_id
),
activity AS (
    SELECT 
        s.sale_id,
        c.cohort_date,
        s.sale_date,
        DATEDIFF(MONTH, c.cohort_date, s.sale_date) AS month_index
    FROM clean_sales s
    JOIN cohort c ON s.sale_id = c.sale_id
)
SELECT 
    cohort_date,
    month_index,
    COUNT(DISTINCT sale_id) AS users
FROM activity
GROUP BY cohort_date, month_index
ORDER BY cohort_date, month_index;------------------------------------------------cohorot analysis to track retention of users over time based on their 1st purchase.


SELECT 
    COUNT(DISTINCT sale_id) AS total_customers,
    COUNT(DISTINCT CASE WHEN order_count > 1 THEN sale_id END) AS repeat_customers
FROM (
    SELECT sale_id, COUNT(*) AS order_count
    FROM clean_sales
    GROUP BY sale_id
) t;-------------------------------------------------------repeated customers and total customers.

SELECT 
    sale_id,
    CASE 
        WHEN COUNT(*) = 1 THEN 'New'
        WHEN MAX(sale_date) < DATEADD(MONTH, -6, GETDATE()) THEN 'Churned'
        ELSE 'Active'
    END AS lifecycle_stage
FROM clean_sales
GROUP BY sale_id;---------------------------------------------------------------------------classifies cus lifecycle stage as new,active,churned based on last purchase.
